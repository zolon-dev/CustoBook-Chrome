{
  "manifest_version": 3,
  "name": "CustoBook for Chrome",
  "version": "0.0.1",
  "description": "あらゆるウェブ小説サイトを統一レイアウトで読めるプラグイン型ウェブ小説リーダー",
  "permissions": [
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "メニュー",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
